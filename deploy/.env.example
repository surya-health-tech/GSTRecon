# Copy to /opt/GSTRecon/.env (repo root, next to docker-compose.prod.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=gstrecon

# Docker web container port on the host (use 8092 on shared servers; 8080 is often taken)
HTTP_PORT=8092

# Bind address for Docker web:
#   0.0.0.0   — public access http://206.189.140.76:8092 (recommended on shared IP)
#   127.0.0.1 — only host nginx can reach it (use with setup-host-nginx.sh + subdomain)
WEB_BIND=0.0.0.0

# Optional: subdomain for host nginx vhost (PracticeFlow / InvoiceAI share port 80)
# SERVER_NAME=gstrecon.yourdomain.com

LOG_LEVEL=INFO
